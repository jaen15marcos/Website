<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects</title>
    <link href="https://fonts.googleapis.com/css?family=Press+Start+2P" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html, body {
            font-family: 'Press Start 2P', cursive;
            font-size: 16px;
            line-height: 1.5;
            background-color: #221;
            color: #fff;
            text-transform: uppercase;
            height: 100%;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem 1rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100%;
        }
        h1 {
            color: #F6EB14;
            text-align: center;
            margin-bottom: 2rem;
            font-size: 2rem;
        }
        ol {
            list-style-type: none;
            counter-reset: project-counter;
            width: 100%;
            max-width: 600px;
        }
        li {
            color: #4FAF44;
            margin-bottom: 1.5rem;
            position: relative;
            padding-left: 3em;
            text-align: left;
        }
        li::before {
            counter-increment: project-counter;
            content: counter(project-counter) ".";
            position: absolute;
            left: 1.5em;
            top: 0;
            font-size: 0.9rem;
            color: #F6EB14;
        }
        .project-title {
            text-decoration: none;
            color: #F6EB14;
            display: inline-block;
            font-size: 0.9rem;
        }
        .project-description {
            font-size: 0.6rem;
            color: #fff090;
            text-transform: none;
            margin-top: 5px;
        }
        .arrow {
            position: absolute;
            left: 0;
            top: 0;
            width: 1.5em;
            text-align: center;
        }
        .arrow i {
            display: none;
            font-size: 0.7rem;
        }
        li:hover .arrow i {
            display: inline-block;
        }
        li:hover {
            cursor: pointer;
            background-color: rgba(255,255,255,0.1);
        }

        @media (max-width: 768px) {
            html, body {
                font-size: 14px;
            }
            .container {
                padding: 1rem 0.5rem;
            }
            h1 {
                font-size: 1.5rem;
            }
        }

        @media (max-width: 480px) {
            html, body {
                font-size: 12px;
            }
            h1 {
                font-size: 1.2rem;
            }
            li {
                padding-left: 2.5em;
            }
            li::before, .project-title {
                font-size: 0.8rem;
            }
            .project-description {
                font-size: 0.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Projects</h1>
        <ol>
            <li>
                <span class="arrow"><i class="fas fa-arrow-right"></i></span>
                <a class="project-title">ETF Pair Trading</a>
                <p class="project-description">Desc1</p>
            </li>
            <li>
                <span class="arrow"><i class="fas fa-arrow-right"></i></span>
                <a class="project-title">A Multi-Order Type Orderbook</a>
                <p class="project-description">Desc2</p>
            </li>
            <li>
                <span class="arrow"><i class="fas fa-arrow-right"></i></span>
                <a class="project-title">Predicting Realized Volatility with ML</a>
                <p class="project-description">Desc3</p>
            </li>
            <li>
                <span class="arrow"><i class="fas fa-arrow-right"></i></span>
                <a class="project-title">FFT Signal Processing for Correlated Signals</a>
                <p class="project-description">Desc 4</p>
            </li>
            <li>
                <span class="arrow"><i class="fas fa-arrow-right"></i></span>
                <a class="project-title">Q Challenges</a>
                <p class="project-description">Desc 5</p>
            </li>
            <li>
                <span class="arrow"><i class="fas fa-arrow-right"></i></span>
                <a class="project-title">Q Library</a>
                <p class="project-description">Desc 6</p>
            </li>
        </ol>
    </div>
</body>
</html>
